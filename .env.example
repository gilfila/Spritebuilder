# Sprite Builder environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Gemini (sprite generation) ---
# Required. Get a key at https://ai.google.dev/gemini-api/docs/api-key
GEMINI_KEY=

# --- Login credentials ---
# Required in any deployed environment. Defaults (admin/cheese) are used
# only if these are unset, and the server will log a warning at startup.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# --- Multi-factor auth (TOTP) ---
# MFA is set up through the app on first login (scan QR, enter code).
# The enrolled secret is persisted to AUTH_STATE_PATH (default:
# .auth_state.json next to this file).
#
# Setting AUTH_TOTP_SECRET here overrides the file-based store and makes
# the secret read-only (useful for Vercel/serverless where the filesystem
# is ephemeral — enroll locally, then paste the persisted secret here).
AUTH_TOTP_SECRET=

# Where the in-app enrollment persists its secret. Override to a writable
# path on hosts where the project directory is read-only (e.g. /tmp on
# Vercel, though /tmp itself doesn't survive cold starts).
# AUTH_STATE_PATH=.auth_state.json

# --- Server ---
# Optional. Port the dev server binds to (default 5000).
PORT=5000
