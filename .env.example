# Sprite Builder environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Gemini (sprite generation) ---
# Required. Get a key at https://ai.google.dev/gemini-api/docs/api-key
GEMINI_KEY=

# --- Login credentials ---
# Required in any deployed environment. Defaults (admin/cheese) are used
# only if these are unset, and the server will log a warning at startup.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# --- Multi-factor auth (TOTP) ---
# MFA is set up through the app on first login (scan QR, enter code).
# Storage precedence (read) and where enrollment writes to:
#   1. AUTH_TOTP_SECRET env var (read-only override)
#   2. Vercel KV / Upstash Redis (KV_REST_API_URL + KV_REST_API_TOKEN)
#   3. AUTH_STATE_PATH file (default: .auth_state.json next to this file)
#
# On Vercel the filesystem is read-only, so either link a KV store to the
# project (auto-sets the KV_REST_API_* vars) or set AUTH_TOTP_SECRET here.
AUTH_TOTP_SECRET=

# Only needed for non-Vercel deployments, to override the state file path.
# AUTH_STATE_PATH=.auth_state.json

# Vercel auto-populates these when you link a KV store. Also accepts the
# Upstash aliases UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Server ---
# Optional. Port the dev server binds to (default 5000).
PORT=5000
